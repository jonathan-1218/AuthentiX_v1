# ── Dependencies ────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Environment & Secrets ────────────────────────────────────
# All .env variants — covers .env, .env.local, .env.production, etc.
.env
.env.*
!.env.example        # allow the example template to be committed

# Firebase service-account keys (JSON with private_key field)
firebase-to-blockchain/firebaseKey.json
**/serviceAccountKey.json
**/*-firebase-adminsdk-*.json
**/firebase-key.json
**/firebase-credentials.json

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx

# Hardhat / Ethereum
contracts/deployed_address.txt   # contains deployer wallet address & tx hashes
contracts/.env
contracts/.env.*

# ── Build Output ─────────────────────────────────────────────
dist/
build/
.next/
out/

# ── OS / Editor ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/*.log
.idea/
